# Paste your IBM Quantum Platform credentials on the export lines below.
# Do not paste them into these comment lines.
#
# Then either:
#   source .ibm_runtime.env
# or:
#   python activate_ibm_runtime.py
#
# Recommended default channel per IBM docs:
export QISKIT_IBM_CHANNEL=ibm_quantum_platform

# Paste your IBM Cloud API key after the equals sign on this line.
export QISKIT_IBM_TOKEN=T9AovCwhegicbH0hC9PmZTM-VQPijtAiGfWLheydlo1a

# Paste your IBM Quantum Platform instance CRN after the equals sign on this line.
export QISKIT_IBM_INSTANCE=crn:v1:bluemix:public:quantum-computing:us-east:a/6abe90abe54a4a089a2bb0eeb6aa05aa:6c0486d1-1270-40eb-9f00-b2df7cd3d69e::

